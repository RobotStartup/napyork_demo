# ═══════════════════════════════════════════
# MewsFlow AI — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# OpenAI API Key (NEVER hardcode this in your code)
OPENAI_API_KEY=sk-proj-your-key-here

# Mews API credentials
MEWS_API_URL=https://api.mews.com
MEWS_CLIENT_TOKEN=your-mews-client-token
MEWS_ACCESS_TOKEN=your-mews-access-token

# Spring Boot OTA service URL
SPRING_BOOT_URL=http://localhost:8080

# Vector database storage directory
VECTOR_DB_DIR=./vector_store

# ── Optional: LangSmith Observability ──
# Uncomment to enable full LLM tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key
# LANGCHAIN_PROJECT=mewsflow-ai

# ── Optional: Pinecone (production vector DB) ──
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_INDEX=napyork-knowledge
